<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_main"
    app:startDestination="@id/splashFragment">

    <action
        android:id="@+id/actionToMain"
        app:destination="@id/mainFragment" />

    <!--Main-->
    <fragment
        android:id="@+id/mainFragment"
        android:name="ghazimoradi.soheil.weather.ui.fragments.main.MainFragment"
        android:label="fragment_main"
        tools:layout="@layout/fragment_main" />

    <!--Add city-->
    <action
        android:id="@+id/actionToAddCity"
        app:destination="@id/addCityFragment" />

    <dialog
        android:id="@+id/addCityFragment"
        android:name="ghazimoradi.soheil.weather.ui.fragments.addcity.AddCityFragment"
        android:label="fragment_cities_list"
        tools:layout="@layout/fragment_add_city" />

    <!--Cities list-->
    <action
        android:id="@+id/actionToCitiesList"
        app:destination="@id/citiesListFragment" />

    <dialog
        android:id="@+id/citiesListFragment"
        android:name="ghazimoradi.soheil.weather.ui.fragments.cities.CitiesListFragment"
        android:label="citiesListFragment"
        tools:layout="@layout/fragment_cities_list" />
    <!--Info-->

    <action
        android:id="@+id/actionToInfo"
        app:destination="@id/infoFragment" />

    <dialog
        android:id="@+id/infoFragment"
        android:name="ghazimoradi.soheil.weather.ui.fragments.info.InfoFragment"
        android:label="fragment_info"
        tools:layout="@layout/fragment_info">
        <argument
            android:name="Data"
            app:argType="ghazimoradi.soheil.weather.data.models.main.ResponseCurrentWeather" />
    </dialog>

    <fragment
        android:id="@+id/splashFragment"
        android:name="ghazimoradi.soheil.weather.ui.fragments.splash.SplashFragment"
        android:label="fragment_splash"
        tools:layout="@layout/fragment_splash" />
</navigation>