<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.Weather" parent="Theme.Material3.DayNight.NoActionBar"/>

    <style name="Theme.Weather" parent="Base.Theme.Weather" >
        <item name="android:windowTranslucentNavigation">true</item>
    </style>

    <style name="ColoredShadowLight">
        <item name="android:outlineSpotShadowColor" tools:targetApi="p">@color/cornflowerBlue</item>
        <item name="android:outlineAmbientShadowColor" tools:targetApi="p">@color/cornflowerBlue</item>
    </style>

    <!--Bottom sheet dialog-->
    <style name="RemoveDialogBackground" parent="Theme.AppCompat.Light.Dialog">
        <item name="android:windowBackground">@null</item>
        <item name="android:windowSoftInputMode">adjustResize|stateVisible</item>
    </style>

</resources>